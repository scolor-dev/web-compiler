{
  "name": "local-code-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build crates/compiler --target web --out-dir ../../src/wasm/compiler --release",
    "predev": "npm run wasm",
    "dev": "vite",
    "prebuild": "npm run wasm",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "test": "vitest run && node scripts/test-c-toolchain.mjs && cargo test --manifest-path crates/compiler/Cargo.toml"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.11.2",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.1",
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.6",
    "@yowasp/clang": "^22.0.0-git20542-10",
    "acorn": "^8.15.0",
    "eslint-scope": "^8.4.0",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/eslint-scope": "^3.7.7",
    "@types/node": "^24.0.14",
    "@vitejs/plugin-vue": "^6.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.3",
    "wasm-pack": "^0.15.0"
  }
}
